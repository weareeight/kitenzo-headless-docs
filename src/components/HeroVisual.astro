---
// Hero animation that *shows what headless does*: the Kitenzo bundle
// experience running inside a custom storefront — items get selected, the
// discount applies, and the bundle is added to cart. Pure CSS loop.
// Styles live in src/styles/theme.css (global) so they always load.
---
<div class="hv" role="img" aria-label="A Kitenzo bundle being built inside a custom headless storefront: items are selected, a 10% bundle discount applies, and the bundle is added to cart.">
  <div class="hv__chrome">
    <span class="hv__dot"></span><span class="hv__dot"></span><span class="hv__dot"></span>
    <span class="hv__url">your-store.com/bundles/build-your-box</span>
  </div>

  <div class="hv__app">
    <div class="hv__head">
      <span class="hv__kicker">Build your box</span>
      <span class="hv__state">
        <span class="hv__state--pick">Pick 3 items</span>
        <span class="hv__state--done">Bundle ready</span>
      </span>
    </div>

    <div class="hv__tiles">
      <div class="hv__tile" data-i="1"><span class="hv__sw"></span><span class="hv__tick"></span><span class="hv__cap">Roast</span></div>
      <div class="hv__tile" data-i="2"><span class="hv__sw"></span><span class="hv__tick"></span><span class="hv__cap">Grinder</span></div>
      <div class="hv__tile" data-i="3"><span class="hv__sw"></span><span class="hv__tick"></span><span class="hv__cap">Filters</span></div>
    </div>

    <div class="hv__bar"><i></i></div>

    <div class="hv__pay">
      <div class="hv__price">
        <span class="hv__was">$59.98</span>
        <span class="hv__now">$53.98</span>
        <span class="hv__off">10% off</span>
      </div>
      <button class="hv__cta" type="button">Add bundle to cart</button>
    </div>
  </div>

  <div class="hv__foot">
    <span class="hv__live"><i></i>Live</span>
    <span>Bundle data via Kitenzo API</span>
  </div>
</div>
